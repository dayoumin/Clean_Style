# AI API 키 (하나 이상 설정)
# OpenRouter 권장 — 하나의 키로 Claude, GPT 등 여러 모델 사용 가능
OPENROUTER_API_KEY=sk-or-xxxxx

# 또는 개별 키 (OpenRouter 없을 때 폴백)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# 앱 URL (OpenRouter Referer용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 관리자 대시보드 접근 비밀번호 (설정 시 /admin/dashboard 접근 제한)
ADMIN_SECRET=your-secret-here
